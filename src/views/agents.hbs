{{! Agents Page }}

<div class="page-header">
  <h1 class="page-title">рҹ‘Ҙ Agent е·ҘдҪңиҙҹиҪҪ</h1>
  <div class="page-actions">
    <button class="btn btn-secondary" onclick="refreshAgents()">
      <span class="btn-icon">рҹ”„</span> еҲ·ж–°
    </button>
  </div>
</div>

<!-- еҠ иҪҪзҠ¶жҖ?-->
<div class="loading-state" id="loadingState">
  <div class="spinner"></div>
  <p>еҠ иҪҪ Agent ж•°жҚ®...</p>
</div>

<!-- е·ҘдҪңиҙҹиҪҪеӣҫиЎЁ -->
<div class="workload-chart-card" id="workloadChartCard" style="display: none;">
  <h3 class="chart-title">рҹ“Ҡ Agent е·ҘдҪңиҙҹиҪҪеҜ№жҜ”</h3>
  <div class="chart-container">
    <canvas id="workloadChart"></canvas>
  </div>
</div>

<!-- Agent еҚЎзүҮеҲ—иЎЁ -->
<div class="agents-grid" id="agentsGrid">
  <!-- Agent еҚЎзүҮе°ҶеңЁиҝҷйҮҢжёІжҹ“ -->
</div>

<!-- з©әзҠ¶жҖ?-->
<div class="empty-state" id="emptyState" style="display: none;">
  <div class="empty-state-icon">рҹ‘Ҙ</div>
  <div class="empty-state-title">жҡӮж—  Agent ж•°жҚ®</div>
  <div class="empty-state-description">еҪ“еүҚжІЎжңүйЎ№зӣ®еҢ…еҗ«д»»еҠЎж•°жҚ®</div>
</div>

<script>

// е…ЁеұҖзҠ¶жҖ?let agentsData = [];
let workloadChart = null;

// еҲқе§ӢеҢ?document.addEventListener('DOMContentLoaded', () => {
  loadAgents();
});

async function loadAgents() {
  showLoading(true);
  
  try {
    const response = await fetch(`${API_BASE}/agents`);
    const result = await response.json();
    
    if (result.success) {
      agentsData = result.data;
      renderAgentCards(agentsData);
      renderWorkloadChart(agentsData);
    } else {
      showError('еҠ иҪҪ Agent ж•°жҚ®еӨұиҙҘ');
    }
  } catch (error) {
    console.error('Failed to load agents:', error);
    showError('еҠ иҪҪ Agent ж•°жҚ®еӨұиҙҘ');
  } finally {
    showLoading(false);
  }
}

function renderAgentCards(agents) {
  const grid = document.getElementById('agentsGrid');
  const emptyState = document.getElementById('emptyState');
  
  if (!agents || agents.length === 0) {
    grid.style.display = 'none';
    emptyState.style.display = 'flex';
    return;
  }
  
  grid.style.display = 'grid';
  emptyState.style.display = 'none';
  
  grid.innerHTML = agents.map(agent => `
    <div class="agent-card" onclick="toggleAgentDetails('${agent.name}')">
      <div class="agent-header">
        <div class="agent-icon"><img src="/assets/icons/agent-${agent.name.toLowerCase()}.svg" alt="${agent.name}"></div>
        <div class="agent-name">${agent.name}</div>
        <div class="agent-toggle" id="toggle-${agent.name}">в–?/div>
      </div>
      <div class="agent-stats">
        <div class="stat-item waiting">
          <span class="stat-value">${agent.tasks.waiting}</span>
          <span class="stat-label">зӯүеҫ…</span>
        </div>
        <div class="stat-item in-progress">
          <span class="stat-value">${agent.tasks.inProgress}</span>
          <span class="stat-label">иҝӣиЎҢдё?/span>
        </div>
        <div class="stat-item done">
          <span class="stat-value">${agent.tasks.done}</span>
          <span class="stat-label">е®ҢжҲҗ</span>
        </div>
      </div>
      <div class="agent-progress">
        <div class="progress-bar">
          <div class="progress-fill done" style="width: ${agent.tasks.total > 0 ? (agent.tasks.done / agent.tasks.total * 100) : 0}%"></div>
          <div class="progress-fill in-progress" style="width: ${agent.tasks.total > 0 ? (agent.tasks.inProgress / agent.tasks.total * 100) : 0}%"></div>
        </div>
        <div class="progress-label">${agent.tasks.total} дёӘд»»еҠ?/div>
      </div>
    </div>
  `).join('');
}

function renderWorkloadChart(agents) {
  const chartCard = document.getElementById('workloadChartCard');
  
  if (!agents || agents.length === 0) {
    chartCard.style.display = 'none';
    return;
  }
  
  chartCard.style.display = 'block';
  
  const ctx = document.getElementById('workloadChart');
  if (!ctx) return;
  
  // й”ҖжҜҒж—§еӣҫиЎЁ
  if (workloadChart) {
    workloadChart.destroy();
  }
  
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  const textColor = isDark ? '#94A3B8' : '#64748B';
  const gridColor = isDark ? '#334155' : '#E2E8F0';
  
  workloadChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: agents.map(a => a.name),
      datasets: [
        {
          label: 'зӯүеҫ…',
          data: agents.map(a => a.tasks.waiting),
          backgroundColor: '#F59E0B'
        },
        {
          label: 'иҝӣиЎҢдё?,
          data: agents.map(a => a.tasks.inProgress),
          backgroundColor: '#3B82F6'
        },
        {
          label: 'е·Іе®ҢжҲ?,
          data: agents.map(a => a.tasks.done),
          backgroundColor: '#10B981'
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { color: textColor }
        }
      },
      scales: {
        x: {
          stacked: true,
          ticks: { color: textColor },
          grid: { color: gridColor }
        },
        y: {
          stacked: true,
          beginAtZero: true,
          ticks: { color: textColor, stepSize: 1 },
          grid: { color: gridColor },
          suggestedMax: Math.ceil(
            Math.max(...agents.map(a => (a.tasks.waiting || 0) + (a.tasks.inProgress || 0) + (a.tasks.done || 0))) * 1.2
          )
        }
      }
    }
  });
}

function toggleAgentDetails(agentName) {
  const toggle = document.getElementById(`toggle-${agentName}`);
  const cards = document.querySelectorAll('.agent-card');
  
  // з®ҖеҢ–зүҲпјҡеҸӘжҳҜеҠЁз”»ж•Ҳжһ?  cards.forEach(card => {
    if (card.querySelector('.agent-name').textContent === agentName) {
      card.classList.toggle('expanded');
    }
  });
}

function showLoading(show) {
  document.getElementById('loadingState').style.display = show ? 'flex' : 'none';
}

function showError(message) {
  alert(message);
}

function refreshAgents() {
  loadAgents();
}

// дё»йўҳеҲҮжҚўж—¶жӣҙж–°еӣҫиЎ?document.addEventListener('themeChanged', () => {
  if (agentsData.length > 0) {
    renderWorkloadChart(agentsData);
  }
});
</script>

<style>
