    <div class="stat-content">
      <div class="stat-value" id="totalBugs">-</div>
      <div class="stat-label">Bug و€»و•°</div>
    </div>
  </div>
  <div class="stat-card warning">
    <div class="stat-icon">ًں”´</div>
    <div class="stat-content">
      <div class="stat-value" id="openBugs">-</div>
      <div class="stat-label">وœھن؟®ه¤?/div>
    </div>
  </div>
  <div class="stat-card success">
    <div class="stat-icon">âœ?/div>
    <div class="stat-content">
      <div class="stat-value" id="fixedBugs">-</div>
      <div class="stat-label">ه·²ن؟®ه¤?/div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">ًں“ٹ</div>
    <div class="stat-content">
