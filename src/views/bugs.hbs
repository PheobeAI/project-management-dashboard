<!-- ç­›é€‰و ڈ -->
<div class="filter-bar">
  <div class="filter-group">
    <label>çٹ¶و€?</label>
    <select id="statusFilter" onchange="filterBugs()">
      <option value="all">ه…¨éƒ¨</option>
      <option value="open">وœھن؟®ه¤?/option>
      <option value="fixed">ه·²ن؟®ه¤?/option>
    </select>
  </div>
  <div class="filter-group">
    <label>ن¸¥é‡چç¨‹ه؛¦:</label>
    <select id="severityFilter" onchange="filterBugs()">
      <option value="all">ه…¨éƒ¨</option>
      <option value="critical">Critical</option>
      <option value="high">High</option>
      <option value="medium">Medium</option>
      <option value="minor">Minor</option>
    </select>
  </div>
</div>

<!-- Bug è¶‹هٹ؟ه›?-->
<div class="bug-trend-card" id="bugTrendCard">
  <h3 class="card-title">ًں“ˆ Bug è¶‹هٹ؟</h3>
  <div class="chart-container">
    <canvas id="bugTrendChart"></canvas>
  </div>
</div>

<!-- هٹ è½½çٹ¶و€?-->
<div class="loading-state" id="loadingState">
  <div class="spinner"></div>
  <p>هٹ è½½ Bug و•°وچ®...</p>
</div>

<!-- Bug هˆ—è،¨ -->
<div class="bugs-list" id="bugsList">
  <!-- Bug é،¹ه°†هœ¨è؟™é‡Œو¸²وں?-->
</div>

<!-- ç©؛çٹ¶و€?-->
<div class="empty-state" id="emptyState" style="display: none;">
  <div class="empty-state-icon">ًںگ›</div>
  <div class="empty-state-title">وڑ‚و—  Bug و•°وچ®</div>
  <div class="empty-state-description">ه½“ه‰چو²،وœ‰é،¹ç›®هŒ…هگ« Bug è®°ه½•</div>
</div>

<script>

// ه…¨ه±€çٹ¶و€?let bugsData = [];
let bugTrendChart = null;
let currentFilter = { status: 'all', severity: 'all' };

// هˆ‌ه§‹هŒ?document.addEventListener('DOMContentLoaded', () => {
  // ه؛”ç”¨ن؟‌ه­کçڑ„ن¸»é¢?  const savedTheme = localStorage.getItem('theme');
  if (savedTheme) document.documentElement.setAttribute('data-theme', savedTheme);
  
  loadBugsData();
  loadBugTrend();
});

// هٹ è½½ Bug و•°وچ®
async function loadBugsData() {
  showLoading(true);
  
  try {
    const response = await fetch(`${API_BASE}/bugs/stats`);
    const result = await response.json();
    
    if (result.success) {
      renderBugStats(result.data);
    }
    
    // هٹ è½½ Bug هˆ—è،¨
    const listResponse = await fetch(`${API_BASE}/bugs`);
    const listResult = await listResponse.json();
    
    if (listResult.success) {
      bugsData = listResult.data;
      renderBugList(bugsData);
    }
  } catch (error) {
    console.error('Failed to load bugs:', error);
    showError('هٹ è½½ Bug و•°وچ®ه¤±è´¥');
  } finally {
    showLoading(false);
  }
}

// هٹ è½½ Bug è¶‹هٹ؟
async function loadBugTrend() {
  try {
    const response = await fetch(`${API_BASE}/bugs/trend?days=7`);
    const result = await response.json();
    
    if (result.success) {
      renderBugTrendChart(result.data);
    }
  } catch (error) {
    console.warn('Failed to load bug trend:', error);
  }
}

// و¸²وں“ Bug ç»ںè®،
function renderBugStats(stats) {
  document.getElementById('totalBugs').textContent = stats.total || 0;
  document.getElementById('openBugs').textContent = stats.open || 0;
  document.getElementById('fixedBugs').textContent = stats.fixed || 0;
  document.getElementById('fixRate').textContent = (stats.progress || 0) + '%';
}

// و¸²وں“ Bug è¶‹هٹ؟ه›¾è،¨
function renderBugTrendChart(trend) {
  const ctx = document.getElementById('bugTrendChart');
  if (!ctx) return;
  
  if (bugTrendChart) {
    bugTrendChart.destroy();
  }
  
  // و— هژ†هڈ²و•°وچ®و—¶وک¾ç¤؛وڈگç¤؛
  const hasData = trend.some(t => t.total > 0 || t.fixed > 0 || t.open > 0);
  if (!hasData) {
    ctx.parentElement.style.position = 'relative';
    const existing = ctx.parentElement.querySelector('.no-trend-data');
    if (!existing) {
      const msg = document.createElement('div');
      msg.className = 'no-trend-data';
      msg.style.cssText = 'position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:#94A3B8;font-size:14px;pointer-events:none;';
      msg.textContent = 'وڑ‚و— هژ†هڈ²è¶‹هٹ؟و•°وچ®';
      ctx.parentElement.appendChild(msg);
    }
    return;
  }
  
  // ن½؟ç”¨ Art وڈگن¾›çڑ„ه›¾è،¨é…چç½?  if (window.ChartConfigs && window.ChartConfigs.getBugTrendChartConfig) {
    const config = window.ChartConfigs.getBugTrendChartConfig(
      trend.map(t => ({ date: t.date.slice(5), count: t.total }))
    );
    bugTrendChart = new Chart(ctx, config);
  } else {
    // ه›‍é€€هˆ°ه†…èپ”é…چç½?    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const textColor = isDark ? '#94A3B8' : '#64748B';
    const gridColor = isDark ? '#334155' : '#E2E8F0';
    
    bugTrendChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: trend.map(t => t.date.slice(5)),
        datasets: [
          {
            label: 'و€?Bug',
            data: trend.map(t => t.total),
            borderColor: '#EF4444',
            backgroundColor: 'rgba(239, 68, 68, 0.1)',
            fill: true,
            tension: 0.3
          },
          {
            label: 'ه·²ن؟®ه¤?,
            data: trend.map(t => t.fixed),
            borderColor: '#10B981',
            backgroundColor: 'rgba(16, 185, 129, 0.1)',
            fill: true,
            tension: 0.3
          },
          {
            label: 'وœھن؟®ه¤?,
            data: trend.map(t => t.open),
            borderColor: '#F59E0B',
            backgroundColor: 'rgba(245, 158, 11, 0.1)',
            fill: true,
            tension: 0.3
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom', labels: { color: textColor } }
        },
        scales: {
          x: { ticks: { color: textColor }, grid: { color: gridColor } },
          y: { beginAtZero: true, ticks: { color: textColor, stepSize: 1 }, grid: { color: gridColor } }
        }
      }
    });
  }
}

// و¸²وں“ Bug هˆ—è،¨
function renderBugList(bugs) {
  const listEl = document.getElementById('bugsList');
  const emptyState = document.getElementById('emptyState');
  
  if (!bugs || bugs.length === 0) {
    listEl.style.display = 'none';
    emptyState.style.display = 'flex';
    return;
  }
  
  listEl.style.display = 'block';
  emptyState.style.display = 'none';
  
  // وŒ‰ن¸¥é‡چç¨‹ه؛¦هˆ†ç»?  const grouped = {
    critical: bugs.filter(b => b.severity === 'critical'),
    high: bugs.filter(b => b.severity === 'high'),
    medium: bugs.filter(b => b.severity === 'medium'),
    minor: bugs.filter(b => b.severity === 'minor')
  };
  
  let html = '';
  
  for (const [severity, items] of Object.entries(grouped)) {
    if (items.length === 0) continue;
    
    const severityLabels = {
      critical: 'ًں”´ Critical',
      high: 'ًںں  High',
      medium: 'ًںں، Medium',
      minor: 'ًں”µ Minor'
    };
    
    html += `
      <div class="bug-group">
        <div class="bug-group-header ${severity}">
          ${severityLabels[severity]} (${items.length})
        </div>
        <div class="bug-group-list">
          ${items.map(bug => renderBugItem(bug)).join('')}
        </div>
      </div>
    `;
  }
  
  listEl.innerHTML = html || '<p class="no-bugs">و²،وœ‰ç¬¦هگˆç­›é€‰و‌،ن»¶çڑ„ Bug</p>';
}

function renderBugItem(bug) {
  const statusIcon = bug.status === 'fixed' ? 'âœ? : 'ًں”´';
  const statusClass = bug.status === 'fixed' ? 'fixed' : 'open';
  const date = bug.created_at ? new Date(bug.created_at).toLocaleDateString('zh-CN') : '-';
  const fixedDate = bug.fixed_at ? new Date(bug.fixed_at).toLocaleDateString('zh-CN') : '-';
  
  return `
    <div class="bug-item ${statusClass}">
      <div class="bug-status">${statusIcon}</div>
      <div class="bug-content">
        <div class="bug-title">${bug.title || bug.id}</div>
        <div class="bug-meta">
          <span class="bug-project">${bug.projectName || 'وœھçں¥é،¹ç›®'}</span>
          <span class="bug-date">هˆ›ه»؛: ${date}</span>
          ${bug.status === 'fixed' ? `<span class="bug-fixed-date">ن؟®ه¤چ: ${fixedDate}</span>` : ''}
        </div>
      </div>
      <div class="bug-actions">
        <button class="btn btn-sm" onclick="viewBugDetail('${bug.id}')">وں¥çœ‹</button>
      </div>
    </div>
  `;
}

// ç­›é€?Bug
function filterBugs() {
  currentFilter.status = document.getElementById('statusFilter').value;
  currentFilter.severity = document.getElementById('severityFilter').value;
  
  let filtered = [...bugsData];
  
  if (currentFilter.status !== 'all') {
    filtered = filtered.filter(b => b.status === currentFilter.status);
  }
  
  if (currentFilter.severity !== 'all') {
    filtered = filtered.filter(b => b.severity === currentFilter.severity);
  }
  
  renderBugList(filtered);
}

// وں¥çœ‹ Bug è¯¦وƒ…
function viewBugDetail(bugId) {
  // ç®€هŒ–ه®‍çژ°ï¼ڑهڈھوک¯وک¾ç¤؛ن¸€ن¸ھوڈگç¤?  const bug = bugsData.find(b => b.id === bugId);
  if (bug) {
    alert(`Bug: ${bug.title || bugId}\nçٹ¶و€? ${bug.status}\nن¸¥é‡چç¨‹ه؛¦: ${bug.severity}\né،¹ç›®: ${bug.projectName}`);
  }
}

function showLoading(show) {
  document.getElementById('loadingState').style.display = show ? 'flex' : 'none';
}

function showError(message) {
  alert(message);
}

function refreshBugs() {
  loadBugsData();
  loadBugTrend();
}

// ن¸»é¢کهˆ‡وچ¢و—¶و›´و–°ه›¾è،?document.addEventListener('themeChanged', () => {
  if (bugsData.length > 0) {
    loadBugTrend();
  }
});
</script>

