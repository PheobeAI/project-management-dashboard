{{! Documents Page - Enhanced }}

<div class="page-header">
  <h1 class="page-title">рҹ“„ Documents</h1>
  <div class="page-actions">
    <input type="text" id="searchInput" class="search-input" placeholder="жҗңзҙўж–ҮжЎЈ..." oninput="searchDocuments()">
    <select id="projectFilter" class="filter-select" onchange="filterDocuments()">
      <option value="all">жүҖжңүйЎ№зӣ?/option>
    </select>
    <select id="typeFilter" class="filter-select" onchange="filterDocuments()">
      <option value="all">жүҖжңүзұ»еһ?/option>
      <option value="md">Markdown</option>
      <option value="json">JSON</option>
      <option value="yaml">YAML</option>
    </select>
    <button class="btn btn-secondary" onclick="refreshDocuments()">
      <span class="btn-icon">рҹ”„</span>
    </button>
  </div>
</div>

<!-- дё»еҶ…е®№еҢәпјҡе·Ұдҫ§ж–ҮжЎЈж ‘ + еҸідҫ§йў„и§Ҳ -->
<div class="documents-layout">
  <!-- е·Ұдҫ§пјҡж–ҮжЎЈж ‘ -->
  <div class="doc-tree-panel">
    <div class="panel-header">
      <span class="panel-title">рҹ“Ғ ж–ҮжЎЈж ?/span>
    </div>
    <div class="doc-tree" id="docTree">
      <!-- ж–ҮжЎЈж ‘е°ҶеңЁиҝҷйҮҢжёІжҹ?-->
    </div>
  </div>

  <!-- еҸідҫ§пјҡж–ҮжЎЈйў„и§?-->
  <div class="doc-preview-panel">
    <div class="preview-header" id="previewHeader">
      <div class="preview-title" id="previewTitle">йҖүжӢ©ж–ҮжЎЈ</div>
      <div class="preview-path" id="previewPath"></div>
    </div>
    <div class="preview-actions" id="previewActions" style="display: none;">
      <button class="btn btn-preview" onclick="downloadDocument()">дёӢиҪҪ</button>
      <button class="btn btn-preview primary" onclick="shareDocument()">еҲҶдә«</button>
    </div>
    <div class="preview-content" id="previewContent">
      <div class="preview-placeholder">
        <div class="placeholder-icon">рҹ“„</div>
        <div class="placeholder-text">д»Һе·Ұдҫ§йҖүжӢ©дёҖдёӘж–ҮжЎЈжҹҘзңӢйў„и§?/div>
      </div>
    </div>
    <div class="preview-footer" id="previewFooter" style="display: none;">
      <span class="version-info" id="versionInfo"></span>
    </div>
  </div>
</div>

<!-- еҠ иҪҪзҠ¶жҖ?-->
<div class="loading-state" id="loadingState">
  <div class="spinner"></div>
  <p>еҠ иҪҪж–ҮжЎЈж•°жҚ®...</p>
</div>

<script>

// ж–ҮжЎЈзұ»еһӢйўңиүІ
const TYPE_COLORS = {
  requirements: '#3B82F6',
  design: '#8B5CF6',
  review: '#10B981',
  task: '#F59E0B',
  md: '#64748B',
  json: '#F97316',
  yaml: '#06B6D4',
  txt: '#6B7280'
};

let documentsData = [];
let currentDoc = null;
let currentFilter = { search: '', project: 'all', type: 'all' };

document.addEventListener('DOMContentLoaded', () => {
  loadDocuments();
});

async function loadDocuments() {
  showLoading(true);
  
  try {
    const response = await fetch(`${API_BASE}/documents`);
    const result = await response.json();
    
    if (result.success) {
      documentsData = result.data;
      buildDocumentTree();
      populateProjectFilter();
    }
  } catch (error) {
    console.error('Failed to load documents:', error);
  } finally {
    showLoading(false);
  }
}

function buildDocumentTree() {
  // жҢүйЎ№зӣ®еҲҶз»?  const projects = {};
  
  documentsData.forEach(doc => {
    const projectName = doc.projectName || 'жңӘзҹҘйЎ№зӣ®';
    if (!projects[projectName]) {
      projects[projectName] = {
        name: projectName,
        children: {}
      };
    }
    
    // и§Јжһҗи·Ҝеҫ„иҺ·еҸ–еҲҶзұ»
    const parts = doc.relativePath?.split(/[\/\\]/) || ['', doc.name];
    const category = getCategory(parts);
    
    if (!projects[projectName].children[category]) {
      projects[projectName].children[category] = {
        name: category,
        icon: getCategoryIcon(category),
        color: TYPE_COLORS[category.toLowerCase()] || TYPE_COLORS.md,
        docs: []
      };
    }
    projects[projectName].children[category].docs.push(doc);
  });
  
  // жёІжҹ“ж ?  const treeContainer = document.getElementById('docTree');
  let html = '';
  
  for (const [projectName, project] of Object.entries(projects)) {
    const isExpanded = projectName === Object.keys(projects)[0]; // й»ҳи®Өеұ•ејҖз¬¬дёҖдё?    
    html += `
      <div class="tree-project">
        <div class="tree-item project ${isExpanded ? 'expanded' : ''}" onclick="toggleProject(this)">
          <span class="tree-arrow">${isExpanded ? 'в–? : 'в–?}</span>
          <span class="tree-folder" style="background: ${TYPE_COLORS.task}">рҹ“Ғ</span>
          <span class="tree-label">${projectName}</span>
          <span class="tree-count">(${Object.values(project.children).reduce((sum, c) => sum + c.docs.length, 0)})</span>
        </div>
        <div class="tree-children" style="display: ${isExpanded ? 'block' : 'none'}">
          ${Object.entries(project.children).map(([catName, cat]) => renderCategory(cat, catName)).join('')}
        </div>
      </div>
    `;
  }
  
  treeContainer.innerHTML = html || '<div class="no-docs">жҡӮж— ж–ҮжЎЈ</div>';
}

function renderCategory(category, catName) {
  const isExpanded = true;
  let html = `
    <div class="tree-category">
      <div class="tree-item category ${isExpanded ? 'expanded' : ''}" onclick="toggleCategory(this)">
        <span class="tree-arrow">${isExpanded ? 'в–? : 'в–?}</span>
        <span class="tree-folder" style="background: ${category.color}">${category.icon}</span>
        <span class="tree-label">${category.name}</span>
        <span class="tree-count">(${category.docs.length})</span>
      </div>
      <div class="tree-children" style="display: ${isExpanded ? 'block' : 'none'}">
  `;
  
  category.docs.forEach(doc => {
    html += `
      <div class="tree-item file" onclick="selectDocument('${encodeURIComponent(doc.path)}', '${encodeURIComponent(doc.name)}', '${encodeURIComponent(doc.projectName || '')}')">
        <span class="tree-file-icon" style="background: ${getFileColor(doc.type)}">${getFileIcon(doc.type)}</span>
        <span class="tree-label">${doc.name}</span>
      </div>
    `;
  });
  
  html += '</div></div>';
  return html;
}

function getCategory(parts) {
  if (parts.length > 1) {
    const first = parts[0].toLowerCase();
    if (first.includes('йңҖжұ?) || first.includes('requirement')) return 'йңҖжұӮж–ҮжЎ?;
    if (first.includes('и®ҫи®Ў') || first.includes('design')) return 'и®ҫи®Ўж–ҮжЎЈ';
    if (first.includes('иҜ„е®Ў') || first.includes('review')) return 'иҜ„е®Ўи®°еҪ•';
    if (first.includes('д»»еҠЎ') || first.includes('task')) return 'д»»еҠЎж–ҮжЎЈ';
  }
  return 'е…¶д»–ж–ҮжЎЈ';
}

function getCategoryIcon(category) {
  const icons = {
    'йңҖжұӮж–ҮжЎ?: 'рҹ“„',
    'и®ҫи®Ўж–ҮжЎЈ': 'рҹ“җ',
    'иҜ„е®Ўи®°еҪ•': 'вң?,
    'д»»еҠЎж–ҮжЎЈ': 'рҹ“Ӣ',
    'е…¶д»–ж–ҮжЎЈ': 'рҹ“Ғ'
  };
  return icons[category] || 'рҹ“Ғ';
}

function getFileIcon(type) {
  const icons = {
    md: 'рҹ“қ',
    json: 'рҹ“Ӣ',
    yaml: 'вҡҷпёҸ',
    yml: 'вҡҷпёҸ',
    txt: 'рҹ“„'
  };
  return icons[type?.toLowerCase()] || 'рҹ“„';
}

function getFileColor(type) {
  return TYPE_COLORS[type?.toLowerCase()] || TYPE_COLORS.md;
}

function toggleProject(element) {
  const arrow = element.querySelector('.tree-arrow');
  const children = element.nextElementSibling;
  
  if (children && children.classList.contains('tree-children')) {
    const isExpanded = element.classList.toggle('expanded');
    arrow.textContent = isExpanded ? 'в–? : 'в–?;
    children.style.display = isExpanded ? 'block' : 'none';
  }
}

function toggleCategory(element) {
  const arrow = element.querySelector('.tree-arrow');
  const children = element.nextElementSibling;
  
  if (children && children.classList.contains('tree-children')) {
    const isExpanded = element.classList.toggle('expanded');
    arrow.textContent = isExpanded ? 'в–? : 'в–?;
    children.style.display = isExpanded ? 'block' : 'none';
  }
}

function selectDocument(path, name, projectName) {
  currentDoc = {
    path: decodeURIComponent(path),
    name: decodeURIComponent(name),
    projectName: decodeURIComponent(projectName)
  };
  
  // жӣҙж–°йҖүдёӯзҠ¶жҖ?  document.querySelectorAll('.tree-item.file').forEach(el => el.classList.remove('selected'));
  event.currentTarget.classList.add('selected');
  
  // жӣҙж–°йў„и§Ҳйқўжқҝ
  document.getElementById('previewTitle').textContent = currentDoc.name;
  document.getElementById('previewPath').textContent = currentDoc.projectName;
  document.getElementById('previewActions').style.display = 'flex';
  document.getElementById('previewFooter').style.display = 'flex';
  
  // еҠ иҪҪж–ҮжЎЈеҶ…е®№
  loadDocumentContent(currentDoc.path);
}

async function loadDocumentContent(path) {
  const content = document.getElementById('previewContent');
  content.innerHTML = '<div class="loading-preview"><div class="spinner"></div></div>';
  
  try {
    // з®ҖеҚ•жҳҫзӨәж–ҮжЎЈдҝЎжҒҜдҪңдёәйў„и§?    const doc = documentsData.find(d => d.path === path);
    if (doc) {
      content.innerHTML = `
        <div class="doc-preview-content">
          <div class="preview-meta">
            <span class="meta-item">рҹ“Ғ ${doc.relativePath || doc.path}</span>
            <span class="meta-item">рҹ“Ҡ ${doc.type?.toUpperCase() || 'FILE'}</span>
          </div>
          <div class="preview-placeholder">
            <div class="placeholder-icon">${getFileIcon(doc.type)}</div>
            <div class="placeholder-text">ж–ҮжЎЈеҶ…е®№йў„и§Ҳ</div>
            <div class="placeholder-subtext">${doc.name}</div>
          </div>
        </div>
      `;
      document.getElementById('versionInfo').textContent = `зүҲжң¬: v1.0.0 (${new Date().toLocaleDateString()})`;
    }
  } catch (error) {
    content.innerHTML = '<div class="preview-error">еҠ иҪҪеӨұиҙҘ</div>';
  }
}

function downloadDocument() {
  if (currentDoc) {
    alert(`дёӢиҪҪж–ҮжЎЈ: ${currentDoc.name}`);
  }
}

function shareDocument() {
  if (currentDoc) {
    alert(`еҲҶдә«ж–ҮжЎЈ: ${currentDoc.name}`);
  }
}

function populateProjectFilter() {
  const projects = [...new Set(documentsData.map(d => d.projectName))];
  const select = document.getElementById('projectFilter');
  
  select.innerHTML = '<option value="all">жүҖжңүйЎ№зӣ?/option>' +
    projects.map(p => `<option value="${p}">${p}</option>`).join('');
}

function searchDocuments() {
  currentFilter.search = document.getElementById('searchInput').value.toLowerCase();
  filterDocuments();
}

function filterDocuments() {
  currentFilter.project = document.getElementById('projectFilter').value;
  currentFilter.type = document.getElementById('typeFilter').value;
  
  // йҮҚе»әж ‘е№¶еә”з”ЁиҝҮж»Ө
  let filtered = [...documentsData];
  
  if (currentFilter.search) {
    filtered = filtered.filter(d => 
      d.name.toLowerCase().includes(currentFilter.search) ||
      d.relativePath?.toLowerCase().includes(currentFilter.search)
    );
  }
  
  if (currentFilter.project !== 'all') {
    filtered = filtered.filter(d => d.projectName === currentFilter.project);
  }
  
  if (currentFilter.type !== 'all') {
    filtered = filtered.filter(d => d.type === currentFilter.type);
  }
  
  // йҮҚж–°жһ„е»әж ?  documentsData = filtered;
  buildDocumentTree();
}

function showLoading(show) {
  document.getElementById('loadingState').style.display = show ? 'flex' : 'none';
}

function refreshDocuments() {
  loadDocuments();
}
</script>

