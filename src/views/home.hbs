{{! Home Page Template }}

<!-- Stats Bar -->
<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-value" id="totalProjects">-</div>
    <div class="stat-label">项目总数</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="inProgress">-</div>
    <div class="stat-label">进行中</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="completed">-</div>
    <div class="stat-label">已完成</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="blocked">-</div>
    <div class="stat-label">阻塞</div>
  </div>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
  <div class="search-box">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/>
      <path d="M21 21l-4.35-4.35"/>
    </svg>
    <input type="text" id="searchInput" placeholder="搜索项目...">
  </div>
  <div class="filter-buttons">
    <button class="filter-btn active" data-filter="all">全部</button>
    <button class="filter-btn" data-filter="in_progress">进行中</button>
    <button class="filter-btn" data-filter="done">已完成</button>
    <button class="filter-btn" data-filter="blocked">阻塞</button>
  </div>
  <select id="pathFilter" class="path-filter">
    <option value="">所有路径</option>
  </select>
</div>

<!-- Project Grid -->
<div class="project-grid" id="projectGrid">
  <!-- Loading Skeleton -->
  <div class="project-card skeleton">
    <div class="skeleton-line" style="width: 60%"></div>
    <div class="skeleton-line" style="width: 40%"></div>
    <div class="skeleton-line" style="width: 80%"></div>
  </div>
  <div class="project-card skeleton">
    <div class="skeleton-line" style="width: 60%"></div>
    <div class="skeleton-line" style="width: 40%"></div>
    <div class="skeleton-line" style="width: 80%"></div>
  </div>
  <div class="project-card skeleton">
    <div class="skeleton-line" style="width: 60%"></div>
    <div class="skeleton-line" style="width: 40%"></div>
    <div class="skeleton-line" style="width: 80%"></div>
  </div>
</div>

<!-- Charts Section -->
<div class="charts-section">
  <div class="chart-card">
    <h3 class="chart-title">📊 项目进度对比</h3>
    <canvas id="progressChart"></canvas>
  </div>
  <div class="chart-card">
    <h3 class="chart-title">📈 任务状态分布</h3>
    <canvas id="taskChart"></canvas>
  </div>
  <div class="chart-card">
    <h3 class="chart-title">🎯 阶段分布</h3>
    <canvas id="phaseChart"></canvas>
  </div>
  <div class="chart-card">
    <h3 class="chart-title">📁 路径分布</h3>
    <canvas id="pathChart"></canvas>
  </div>
</div>
