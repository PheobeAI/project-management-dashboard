<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <!-- Art CSS Assets -->
  <link rel="stylesheet" href="/assets/css/variables.css">
  <link rel="stylesheet" href="/static/css/main.css">
  <link rel="stylesheet" href="/static/css/theme.css">
  <link rel="stylesheet" href="/static/css/components.css">
  <link rel="stylesheet" href="/static/css/sidebar.css">
  <link rel="stylesheet" href="/assets/css/animations.css">
</head>
<body>
  <div class="app">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <!-- Logo -->
      <div class="sidebar-header">
        <a href="/" class="sidebar-logo">
          <img src="/assets/logo/logo-main.svg" alt="Logo" class="logo-icon" id="sidebarLogo">
          <span class="sidebar-logo-text">Dashboard</span>
        </a>
      </div>
      
      <!-- Navigation Menu -->
      <nav class="sidebar-nav">
        <a href="/" class="nav-item" data-page="dashboard">
          <span class="nav-icon"><img src="/assets/icons/nav-dashboard.svg" alt="Dashboard"></span>
          <span class="nav-text">Dashboard</span>
        </a>
        <a href="/projects" class="nav-item" data-page="projects">
          <span class="nav-icon"><img src="/assets/icons/nav-projects.svg" alt="Projects"></span>
          <span class="nav-text">Projects</span>
        </a>
        <a href="/agents" class="nav-item" data-page="agents">
          <span class="nav-icon"><img src="/assets/icons/nav-agents.svg" alt="Agents"></span>
          <span class="nav-text">Agents</span>
        </a>
        <a href="/tasks" class="nav-item" data-page="tasks">
          <span class="nav-icon"><img src="/assets/icons/nav-tasks.svg" alt="Tasks"></span>
          <span class="nav-text">Tasks</span>
        </a>
        <a href="/versions" class="nav-item" data-page="versions">
          <span class="nav-icon"><img src="/assets/icons/nav-versions.svg" alt="Versions"></span>
          <span class="nav-text">Versions</span>
        </a>
        <a href="/documents" class="nav-item" data-page="documents">
          <span class="nav-icon"><img src="/assets/icons/nav-documents.svg" alt="Documents"></span>
          <span class="nav-text">Documents</span>
        </a>
        <a href="/bugs" class="nav-item" data-page="bugs">
          <span class="nav-icon"><img src="/assets/icons/nav-bugs.svg" alt="Bugs"></span>
          <span class="nav-text">Bugs</span>
        </a>
        <a href="/log" class="nav-item" data-page="log">
          <span class="nav-icon">📋</span>
          <span class="nav-text">Log</span>
        </a>
        
        <div class="nav-divider"></div>
        
        <a href="/settings" class="nav-item" data-page="settings">
          <span class="nav-icon"><img src="/assets/icons/nav-settings.svg" alt="Settings"></span>
          <span class="nav-text">Settings</span>
        </a>
      </nav>
      
      <!-- Sidebar Toggle -->
      <button class="sidebar-toggle" id="sidebarToggle" title="收缩侧边栏">
        <span class="toggle-icon">◀</span>
        <span class="toggle-text">收缩侧边栏</span>
      </button>
    </aside>
    
    <!-- Main Content Area -->
    <div class="main-wrapper">
      <!-- Header -->
      <header class="header">
        <div class="header-left">
          <h1 class="header-title">{{title}}</h1>
        </div>
        <div class="header-right">
          <button class="btn-icon" id="refreshBtn" title="刷新">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 4v6h-6M1 20v-6h6"/>
              <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
            </svg>
          </button>
          <button class="btn-icon" id="themeBtn" onclick="toggleTheme()" title="切换主题">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"/>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
          </button>
        </div>
      </header>
      
      <!-- Main Content -->
      <main class="main-content">
        <div id="pageError" class="page-error" style="display: none;"></div>
        {{{content}}}
      </main>
    </div>
  </div>

  <!-- Chart.js CDN -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <!-- Art Chart Configs -->
  <script src="/assets/js/charts-phase-config.js"></script>
  <script src="/assets/js/charts-bug-config.js"></script>
  
  <!-- App Scripts -->
  <script src="/static/js/app.js"></script>
  <script src="/static/js/sidebar.js"></script>
  {{#if extraScripts}}
    {{#each extraScripts}}
      <script src="{{this}}"></script>
    {{/each}}
  {{/if}}
</body>
</html>
