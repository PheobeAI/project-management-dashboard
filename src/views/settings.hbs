{{! Settings Page - Enhanced }}

<div class="page-header">
  <h1 class="page-title">⚙️ 系统设置</h1>
</div>

<div class="settings-container">
  <!-- 主题设置 -->
  <section class="settings-section">
    <h2 class="section-title">🎨 主题设置</h2>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">主题模式</div>
        <div class="setting-description">选择界面主题或跟随系统设置</div>
      </div>
      <div class="setting-control">
        <select id="themeSelect" onchange="updateTheme()">
          <option value="light">浅色模式</option>
          <option value="dark">深色模式</option>
          <option value="system">跟随系统</option>
        </select>
      </div>
    </div>
  </section>

  <!-- 路径设置 -->
  <section class="settings-section">
    <h2 class="section-title">📁 项目路径</h2>
    <div class="paths-list" id="pathsList">
      <!-- 路径项将在这里渲染 -->
    </div>
    <button class="btn btn-primary" onclick="showAddPathModal()">
      <span class="btn-icon">+</span> 添加路径
    </button>
  </section>

  <!-- 自动刷新设置 -->
  <section class="settings-section">
    <h2 class="section-title">🔄 自动刷新</h2>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">启用自动刷新</div>
        <div class="setting-description">自动刷新项目数据</div>
      </div>
      <div class="setting-control">
        <label class="toggle">
          <input type="checkbox" id="autoRefreshToggle" onchange="updateAutoRefresh()">
          <span class="toggle-slider"></span>
        </label>
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">刷新间隔</div>
        <div class="setting-description">自动刷新的时间间隔（秒）</div>
      </div>
      <div class="setting-control">
        <select id="refreshInterval" onchange="updateRefreshInterval()">
          <option value="30000">30 秒</option>
          <option value="60000">1 分钟</option>
          <option value="120000">2 分钟</option>
          <option value="300000">5 分钟</option>
        </select>
      </div>
    </div>
  </section>

  <!-- GitHub 设置 -->
  <section class="settings-section">
    <h2 class="section-title">🐙 GitHub 配置</h2>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">GitHub Token</div>
        <div class="setting-description">用于访问 GitHub API 的 Personal Access Token</div>
      </div>
      <div class="setting-control">
        <input type="password" id="githubToken" class="setting-input" placeholder="ghp_xxxxxxxxxxxx" onblur="updateGithubToken()">
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">默认远程仓库</div>
        <div class="setting-description">默认的 Git 远程仓库名称</div>
      </div>
      <div class="setting-control">
        <input type="text" id="defaultRemote" class="setting-input" value="origin" onblur="updateDefaultRemote()">
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">默认分支</div>
        <div class="setting-description">默认的 Git 分支名称</div>
      </div>
      <div class="setting-control">
        <input type="text" id="defaultBranch" class="setting-input" value="main" onblur="updateDefaultBranch()">
      </div>
    </div>
  </section>

  <!-- 通知设置 -->
  <section class="settings-section">
    <h2 class="section-title">🔔 通知设置</h2>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">项目阻塞提醒</div>
        <div class="setting-description">当项目阻塞超过 48 小时时发送提醒</div>
      </div>
      <div class="setting-control">
        <label class="toggle">
          <input type="checkbox" id="blockedNotificationToggle" onchange="updateNotification('blocked')">
          <span class="toggle-slider"></span>
        </label>
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">任务到期提醒</div>
        <div class="setting-description">当任务即将到期时发送提醒</div>
      </div>
      <div class="setting-control">
        <label class="toggle">
          <input type="checkbox" id="taskDueNotificationToggle" onchange="updateNotification('taskDue')">
          <span class="toggle-slider"></span>
        </label>
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">提醒提前时间</div>
        <div class="setting-description">任务到期前多少小时提醒</div>
      </div>
      <div class="setting-control">
        <select id="notificationLeadTime" onchange="updateNotificationLeadTime()">
          <option value="1">1 小时</option>
          <option value="4">4 小时</option>
          <option value="12">12 小时</option>
          <option value="24">24 小时</option>
          <option value="48">48 小时</option>
        </select>
      </div>
    </div>
  </section>

  <!-- 关于 -->
  <section class="settings-section">
    <h2 class="section-title">ℹ️ 关于</h2>
    <div class="about-info">
      <p><strong>Project Management Dashboard</strong></p>
      <p>版本: 1.0.0</p>
      <p>技术栈: HTML5 + Express.js + Handlebars + Chart.js</p>
    </div>
  </section>
</div>

<!-- 添加路径 Modal -->
<div class="modal-overlay" id="addPathModal" style="display: none;">
  <div class="modal">
    <div class="modal-header">
      <h3 id="pathModalTitle">添加项目路径</h3>
      <button class="modal-close" onclick="hideAddPathModal()">×</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="newPathId" value="">
      <div class="form-group">
        <label>路径</label>
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="text" id="newPathInput" class="setting-input" placeholder="C:\Users\Projects" readonly style="flex:1;">
          <button type="button" class="btn btn-sm btn-secondary" onclick="document.getElementById('pathDirPicker').click()">浏览</button>
          <input type="file" id="pathDirPicker" webkitdirectory style="display:none;" onchange="handleDirSelect(this)">
        </div>
      </div>
      <div class="form-group">
        <label>别名</label>
        <input type="text" id="newPathAlias" class="setting-input" placeholder="主项目">
      </div>
      <div class="form-group">
        <label>颜色</label>
        <input type="color" id="newPathColor" value="#3B82F6">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="hideAddPathModal()">取消</button>
      <button class="btn btn-primary" onclick="addPath()">添加</button>
    </div>
  </div>
</div>

<script>
const API_BASE = '/api';

// 加载设置
document.addEventListener('DOMContentLoaded', async () => {
  await loadSettings();
  await loadPaths();
});

// 加载设置
async function loadSettings() {
  try {
    const response = await fetch(`${API_BASE}/settings`);
    const result = await response.json();
    
    if (result.success) {
      const settings = result.data;
      
      // 主题
      document.getElementById('themeSelect').value = settings.theme || 'light';
      
      // 应用主题到 DOM
      if (settings.theme) {
        document.documentElement.setAttribute('data-theme', settings.theme);
      }
      
      // 自动刷新
      document.getElementById('autoRefreshToggle').checked = settings.autoRefresh !== false;
      document.getElementById('refreshInterval').value = settings.refreshInterval || 60000;
      
      // GitHub
      if (settings.githubToken) {
        document.getElementById('githubToken').value = settings.githubToken;
      }
      document.getElementById('defaultRemote').value = settings.defaultRemote || 'origin';
      document.getElementById('defaultBranch').value = settings.defaultBranch || 'main';
      
      // 通知
      if (settings.notifications) {
        document.getElementById('blockedNotificationToggle').checked = settings.notifications.blocked !== false;
        document.getElementById('taskDueNotificationToggle').checked = settings.notifications.taskDue !== false;
        document.getElementById('notificationLeadTime').value = settings.notifications.leadTime || 24;
      }
    }
  } catch (error) {
    console.error('Failed to load settings:', error);
  }
}

// 加载路径
async function loadPaths() {
  try {
    const response = await fetch(`${API_BASE}/paths`);
    const result = await response.json();
    
    if (result.success) {
      renderPaths(result.data);
    }
  } catch (error) {
    console.error('Failed to load paths:', error);
  }
}

// 渲染路径列表
function renderPaths(paths) {
  const container = document.getElementById('pathsList');
  
  if (!paths || paths.length === 0) {
    container.innerHTML = '<p class="no-paths">暂无路径配置</p>';
    return;
  }
  
  container.innerHTML = paths.map(p => `
    <div class="path-item">
      <div class="path-color" style="background-color: ${p.color || '#3B82F6'}"></div>
      <div class="path-info">
        <div class="path-alias">${p.alias || p.path}</div>
        <div class="path-value">${p.path}</div>
      </div>
      <div class="path-status">
        ${p.enabled ? '<span class="status-badge enabled">启用</span>' : '<span class="status-badge disabled">禁用</span>'}
      </div>
      <div class="path-actions">
        <button class="btn btn-sm" onclick="editPath('${p.id}')">编辑</button>
        <button class="btn btn-sm btn-danger" onclick="deletePath('${p.id}')">删除</button>
      </div>
    </div>
  `).join('');
  
  // 存储路径数据供编辑使用
  window.pathData = {};
  paths.forEach(p => { window.pathData[p.id] = p; });
}

// 更新主题
async function updateTheme() {
  const theme = document.getElementById('themeSelect').value;
  
  // 应用主题
  if (theme === 'system') {
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
  } else {
    document.documentElement.setAttribute('data-theme', theme);
  }
  
  // 保存设置
  await saveSettings({ theme });
  
  // 同步到 localStorage（Dashboard 等页面从 localStorage 读取主题）
  localStorage.setItem('theme', theme);
}

// 更新自动刷新
async function updateAutoRefresh() {
  const enabled = document.getElementById('autoRefreshToggle').checked;
  await saveSettings({ autoRefresh: enabled });
}

// 更新刷新间隔
async function updateRefreshInterval() {
  const interval = parseInt(document.getElementById('refreshInterval').value);
  await saveSettings({ refreshInterval: interval });
}

// 更新 GitHub Token
async function updateGithubToken() {
  const token = document.getElementById('githubToken').value;
  await saveSettings({ githubToken: token });
}

// 更新默认远程
async function updateDefaultRemote() {
  const remote = document.getElementById('defaultRemote').value;
  await saveSettings({ defaultRemote: remote });
}

// 更新默认分支
async function updateDefaultBranch() {
  const branch = document.getElementById('defaultBranch').value;
  await saveSettings({ defaultBranch: branch });
}

// 更新通知设置
async function updateNotification(type) {
  const settings = {
    notifications: {
      blocked: document.getElementById('blockedNotificationToggle').checked,
      taskDue: document.getElementById('taskDueNotificationToggle').checked,
      leadTime: parseInt(document.getElementById('notificationLeadTime').value)
    }
  };
  await saveSettings(settings);
}

// 更新提醒提前时间
async function updateNotificationLeadTime() {
  const leadTime = parseInt(document.getElementById('notificationLeadTime').value);
  const settings = {
    notifications: {
      blocked: document.getElementById('blockedNotificationToggle').checked,
      taskDue: document.getElementById('taskDueNotificationToggle').checked,
      leadTime
    }
  };
  await saveSettings(settings);
}

// 保存设置
async function saveSettings(updates) {
  try {
    const response = await fetch(`${API_BASE}/settings`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(updates)
    });
    
    if (!response.ok) {
      console.error('Failed to save settings');
    }
  } catch (error) {
    console.error('Failed to save settings:', error);
  }
}

// 显示添加路径 Modal
// 目录选择器回调
function handleDirSelect(input) {
  if (input.files && input.files.length > 0) {
    // webkitdirectory 返回完整路径（Chromium 系浏览器）
    const fullPath = input.files[0].path || input.files[0].webkitRelativePath.split('/')[0];
    document.getElementById('newPathInput').value = fullPath || '';
  }
}

function showAddPathModal() {
  document.getElementById('newPathId').value = '';
  document.getElementById('newPathInput').value = '';
  document.getElementById('newPathAlias').value = '';
  document.getElementById('newPathColor').value = '#3B82F6';
  document.getElementById('pathModalTitle').textContent = '添加项目路径';
  
  // 先显示弹窗，再触发目录选择器
  const modal = document.getElementById('addPathModal');
  modal.style.display = 'flex';
  
  // 触发隐藏的 webkitdirectory 文件选择器
  const dirPicker = document.getElementById('pathDirPicker');
  if (dirPicker) {
    dirPicker.value = ''; // 重置以便重复选择同一路径
    dirPicker.click();
  }
}

// 隐藏添加路径 Modal
function hideAddPathModal() {
  document.getElementById('addPathModal').style.display = 'none';
  document.getElementById('newPathId').value = '';
  document.getElementById('newPathInput').value = '';
  document.getElementById('newPathAlias').value = '';
  document.getElementById('newPathColor').value = '#3B82F6';
}

// 添加路径
async function addPath() {
  const path = document.getElementById('newPathInput').value.trim();
  const alias = document.getElementById('newPathAlias').value.trim();
  const color = document.getElementById('newPathColor').value;
  
  if (!path) {
    alert('请输入路径');
    return;
  }
  
  try {
    const response = await fetch(`${API_BASE}/paths`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path, alias, color })
    });
    
    const result = await response.json();
    
    if (result.success) {
      hideAddPathModal();
      loadPaths();
    } else {
      alert('添加路径失败: ' + result.error);
    }
  } catch (error) {
    console.error('Failed to add path:', error);
    alert('添加路径失败');
  }
}

// 编辑路径
async function editPath(id) {
  const pathData = window.pathData || {};
  const path = pathData[id];
  
  if (!path) {
    alert('路径不存在');
    return;
  }
  
  selectedColor = path.color || '#3B82F6';
  
  // 填充表单
  document.getElementById('newPathId').value = id;
  document.getElementById('newPathInput').value = path.path || '';
  document.getElementById('newPathAlias').value = path.alias || '';
  document.getElementById('newPathColor').value = selectedColor;
  
  // 切换按钮为更新模式
  const modal = document.getElementById('addPathModal');
  const title = modal ? modal.querySelector('h3') : null;
  const confirmBtn = document.querySelector('#addPathModal .btn-primary');
  if (title) title.textContent = '编辑路径';
  if (confirmBtn) {
    confirmBtn.textContent = '保存';
    confirmBtn.onclick = updatePath;
  }
  
  // 更新颜色选择高亮
  document.querySelectorAll('.color-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.color === selectedColor);
  });
  
  if (modal) modal.style.display = 'flex';
}

// 更新路径
async function updatePath() {
  const id = document.getElementById('newPathId').value;
  const path = document.getElementById('newPathInput').value.trim();
  const alias = document.getElementById('newPathAlias').value.trim();
  const color = document.getElementById('newPathColor').value;
  
  if (!id || !path) {
    alert('请填写完整信息');
    return;
  }
  
  try {
    const response = await fetch(`${API_BASE}/paths/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path, alias, color })
    });
    
    const result = await response.json();
    
    if (result.success) {
      hideAddPathModal();
      loadPaths();
    } else {
      alert('更新路径失败: ' + result.error);
    }
  } catch (error) {
    console.error('Failed to update path:', error);
    alert('更新路径失败');
  }
}

// 删除路径
async function deletePath(id) {
  if (!confirm('确定要删除此路径吗？')) return;
  
  try {
    const response = await fetch(`${API_BASE}/paths/${id}`, {
      method: 'DELETE'
    });
    
    const result = await response.json();
    
    if (result.success) {
      loadPaths();
    } else {
      alert('删除路径失败: ' + result.error);
    }
  } catch (error) {
    console.error('Failed to delete path:', error);
    alert('删除路径失败');
  }
}
</script>

<style>
.settings-container {
  max-width: 800px;
}

