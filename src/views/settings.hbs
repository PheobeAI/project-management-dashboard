{{! Settings Page - Enhanced }}

<div class="page-header">
  <h1 class="page-title">вҡҷпёҸ зі»з»ҹи®ҫзҪ®</h1>
</div>

<div class="settings-container">
  <!-- дё»йўҳи®ҫзҪ® -->
  <section class="settings-section">
    <h2 class="section-title">рҹҺЁ дё»йўҳи®ҫзҪ®</h2>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">дё»йўҳжЁЎејҸ</div>
        <div class="setting-description">йҖүжӢ©з•Ңйқўдё»йўҳжҲ–и·ҹйҡҸзі»з»ҹи®ҫзҪ?/div>
      </div>
      <div class="setting-control">
        <select id="themeSelect" onchange="updateTheme()">
          <option value="light">жө…иүІжЁЎејҸ</option>
          <option value="dark">ж·ұиүІжЁЎејҸ</option>
          <option value="system">и·ҹйҡҸзі»з»ҹ</option>
        </select>
      </div>
    </div>
  </section>

  <!-- и·Ҝеҫ„и®ҫзҪ® -->
  <section class="settings-section">
    <h2 class="section-title">рҹ“Ғ йЎ№зӣ®и·Ҝеҫ„</h2>
    <div class="paths-list" id="pathsList">
      <!-- и·Ҝеҫ„йЎ№е°ҶеңЁиҝҷйҮҢжёІжҹ?-->
    </div>
    <button class="btn btn-primary" onclick="showAddPathModal()">
      <span class="btn-icon">+</span> ж·»еҠ и·Ҝеҫ„
    </button>
  </section>

  <!-- иҮӘеҠЁеҲ·ж–°и®ҫзҪ® -->
  <section class="settings-section">
    <h2 class="section-title">рҹ”„ иҮӘеҠЁеҲ·ж–°</h2>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">еҗҜз”ЁиҮӘеҠЁеҲ·ж–°</div>
        <div class="setting-description">иҮӘеҠЁеҲ·ж–°йЎ№зӣ®ж•°жҚ®</div>
      </div>
      <div class="setting-control">
        <label class="toggle">
          <input type="checkbox" id="autoRefreshToggle" onchange="updateAutoRefresh()">
          <span class="toggle-slider"></span>
        </label>
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">еҲ·ж–°й—ҙйҡ”</div>
        <div class="setting-description">иҮӘеҠЁеҲ·ж–°зҡ„ж—¶й—ҙй—ҙйҡ”пјҲз§’пјү</div>
      </div>
      <div class="setting-control">
        <select id="refreshInterval" onchange="updateRefreshInterval()">
          <option value="30000">30 з§?/option>
          <option value="60000">1 еҲҶй’ҹ</option>
          <option value="120000">2 еҲҶй’ҹ</option>
          <option value="300000">5 еҲҶй’ҹ</option>
        </select>
      </div>
    </div>
  </section>

  <!-- GitHub и®ҫзҪ® -->
  <section class="settings-section">
    <h2 class="section-title">рҹҗҷ GitHub й…ҚзҪ®</h2>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">GitHub Token</div>
        <div class="setting-description">з”ЁдәҺи®ҝй—® GitHub API зҡ?Personal Access Token</div>
      </div>
      <div class="setting-control">
        <input type="password" id="githubToken" class="setting-input" placeholder="ghp_xxxxxxxxxxxx" onblur="updateGithubToken()">
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">й»ҳи®ӨиҝңзЁӢд»“еә“</div>
        <div class="setting-description">й»ҳи®Өзҡ?Git иҝңзЁӢд»“еә“еҗҚз§°</div>
      </div>
      <div class="setting-control">
        <input type="text" id="defaultRemote" class="setting-input" value="origin" onblur="updateDefaultRemote()">
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">й»ҳи®ӨеҲҶж”Ҝ</div>
        <div class="setting-description">й»ҳи®Өзҡ?Git еҲҶж”ҜеҗҚз§°</div>
      </div>
      <div class="setting-control">
        <input type="text" id="defaultBranch" class="setting-input" value="main" onblur="updateDefaultBranch()">
      </div>
    </div>
  </section>

  <!-- йҖҡзҹҘи®ҫзҪ® -->
  <section class="settings-section">
    <h2 class="section-title">рҹ”” йҖҡзҹҘи®ҫзҪ®</h2>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">йЎ№зӣ®йҳ»еЎһжҸҗйҶ’</div>
        <div class="setting-description">еҪ“йЎ№зӣ®йҳ»еЎһи¶…иҝ?48 е°Ҹж—¶ж—¶еҸ‘йҖҒжҸҗйҶ?/div>
      </div>
      <div class="setting-control">
        <label class="toggle">
          <input type="checkbox" id="blockedNotificationToggle" onchange="updateNotification('blocked')">
          <span class="toggle-slider"></span>
        </label>
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">д»»еҠЎеҲ°жңҹжҸҗйҶ’</div>
        <div class="setting-description">еҪ“д»»еҠЎеҚіе°ҶеҲ°жңҹж—¶еҸ‘йҖҒжҸҗйҶ?/div>
      </div>
      <div class="setting-control">
        <label class="toggle">
          <input type="checkbox" id="taskDueNotificationToggle" onchange="updateNotification('taskDue')">
          <span class="toggle-slider"></span>
        </label>
      </div>
    </div>
    <div class="setting-item">
      <div class="setting-info">
        <div class="setting-label">жҸҗйҶ’жҸҗеүҚж—¶й—ҙ</div>
        <div class="setting-description">д»»еҠЎеҲ°жңҹеүҚеӨҡе°‘е°Ҹж—¶жҸҗйҶ?/div>
      </div>
      <div class="setting-control">
        <select id="notificationLeadTime" onchange="updateNotificationLeadTime()">
          <option value="1">1 е°Ҹж—¶</option>
          <option value="4">4 е°Ҹж—¶</option>
          <option value="12">12 е°Ҹж—¶</option>
          <option value="24">24 е°Ҹж—¶</option>
          <option value="48">48 е°Ҹж—¶</option>
        </select>
      </div>
    </div>
  </section>

  <!-- е…ідәҺ -->
  <section class="settings-section">
    <h2 class="section-title">в„№пёҸ е…ідәҺ</h2>
    <div class="about-info">
      <p><strong>Project Management Dashboard</strong></p>
      <p>зүҲжң¬: 1.0.0</p>
      <p>жҠҖжңҜж Ҳ: HTML5 + Express.js + Handlebars + Chart.js</p>
    </div>
  </section>
</div>

<!-- ж·»еҠ и·Ҝеҫ„ Modal -->
<div class="modal-overlay" id="addPathModal" style="display: none;">
  <div class="modal">
    <div class="modal-header">
      <h3 id="pathModalTitle">ж·»еҠ йЎ№зӣ®и·Ҝеҫ„</h3>
      <button class="modal-close" onclick="hideAddPathModal()">Г—</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="newPathId" value="">
      <div class="form-group">
        <label>и·Ҝеҫ„</label>
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="text" id="newPathInput" class="setting-input" placeholder="C:\Users\Projects" readonly style="flex:1;">
          <button type="button" class="btn btn-sm btn-secondary" onclick="document.getElementById('pathDirectoryPicker').click()">жөҸи§Ҳ</button>
          <input type="file" id="pathDirectoryPicker" webkitdirectory style="display:none;" onchange="handleDirSelect(this)">
        </div>
      </div>
      <div class="form-group">
        <label>еҲ«еҗҚ</label>
        <input type="text" id="newPathAlias" class="setting-input" placeholder="дё»йЎ№зӣ?>
      </div>
      <div class="form-group">
        <label>йўңиүІ</label>
        <input type="color" id="newPathColor" value="#3B82F6">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="hideAddPathModal()">еҸ–ж¶Ҳ</button>
      <button class="btn btn-primary" onclick="addPath()">ж·»еҠ </button>
    </div>
  </div>
</div>

<script>

// еҠ иҪҪи®ҫзҪ®
document.addEventListener('DOMContentLoaded', async () => {
  await loadSettings();
  await loadPaths();
});

// еҠ иҪҪи®ҫзҪ®
async function loadSettings() {
  try {
    const response = await fetch(`${API_BASE}/settings`);
    const result = await response.json();
    
    if (result.success) {
      const settings = result.data;
      
      // дё»йўҳ
      document.getElementById('themeSelect').value = settings.theme || 'light';
      
      // еә”з”Ёдё»йўҳеҲ?DOM
      if (settings.theme) {
        document.documentElement.setAttribute('data-theme', settings.theme);
      }
      
      // иҮӘеҠЁеҲ·ж–°
      document.getElementById('autoRefreshToggle').checked = settings.autoRefresh !== false;
      document.getElementById('refreshInterval').value = settings.refreshInterval || 60000;
      
      // GitHub
      if (settings.githubToken) {
        document.getElementById('githubToken').value = settings.githubToken;
      }
      document.getElementById('defaultRemote').value = settings.defaultRemote || 'origin';
      document.getElementById('defaultBranch').value = settings.defaultBranch || 'main';
      
      // йҖҡзҹҘ
      if (settings.notifications) {
        document.getElementById('blockedNotificationToggle').checked = settings.notifications.blocked !== false;
        document.getElementById('taskDueNotificationToggle').checked = settings.notifications.taskDue !== false;
        document.getElementById('notificationLeadTime').value = settings.notifications.leadTime || 24;
      }
    }
  } catch (error) {
    console.error('Failed to load settings:', error);
  }
}

// еҠ иҪҪи·Ҝеҫ„
async function loadPaths() {
  try {
    const response = await fetch(`${API_BASE}/paths`);
    const result = await response.json();
    
    if (result.success) {
      renderPaths(result.data);
    }
  } catch (error) {
    console.error('Failed to load paths:', error);
  }
}

// жёІжҹ“и·Ҝеҫ„еҲ—иЎЁ
function renderPaths(paths) {
  const container = document.getElementById('pathsList');
  
  if (!paths || paths.length === 0) {
    container.innerHTML = '<p class="no-paths">жҡӮж— и·Ҝеҫ„й…ҚзҪ®</p>';
    return;
  }
  
  container.innerHTML = paths.map(p => `
    <div class="path-item">
      <div class="path-color" style="background-color: ${p.color || '#3B82F6'}"></div>
      <div class="path-info">
        <div class="path-alias">${p.alias || p.path}</div>
        <div class="path-value">${p.path}</div>
      </div>
      <div class="path-status">
        ${p.enabled ? '<span class="status-badge enabled">еҗҜз”Ё</span>' : '<span class="status-badge disabled">зҰҒз”Ё</span>'}
      </div>
      <div class="path-actions">
        <button class="btn btn-sm" onclick="editPath('${p.id}')">зј–иҫ‘</button>
        <button class="btn btn-sm btn-danger" onclick="deletePath('${p.id}')">еҲ йҷӨ</button>
      </div>
    </div>
  `).join('');
  
  // еӯҳеӮЁи·Ҝеҫ„ж•°жҚ®дҫӣзј–иҫ‘дҪҝз”?  window.pathData = {};
  paths.forEach(p => { window.pathData[p.id] = p; });
}

// жӣҙж–°дё»йўҳ
async function updateTheme() {
  const theme = document.getElementById('themeSelect').value;
  
  // еә”з”Ёдё»йўҳ
  if (theme === 'system') {
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
  } else {
    document.documentElement.setAttribute('data-theme', theme);
  }
  
  // дҝқеӯҳи®ҫзҪ®
  await saveSettings({ theme });
  
  // еҗҢжӯҘеҲ?localStorageпјҲDashboard зӯүйЎөйқўд»Һ localStorage иҜ»еҸ–дё»йўҳпј?  localStorage.setItem('theme', theme);
}

// жӣҙж–°иҮӘеҠЁеҲ·ж–°
async function updateAutoRefresh() {
  const enabled = document.getElementById('autoRefreshToggle').checked;
  await saveSettings({ autoRefresh: enabled });
}

// жӣҙж–°еҲ·ж–°й—ҙйҡ”
async function updateRefreshInterval() {
  const interval = parseInt(document.getElementById('refreshInterval').value);
  await saveSettings({ refreshInterval: interval });
}

// жӣҙж–° GitHub Token
async function updateGithubToken() {
  const token = document.getElementById('githubToken').value;
  await saveSettings({ githubToken: token });
}

// жӣҙж–°й»ҳи®ӨиҝңзЁӢ
async function updateDefaultRemote() {
  const remote = document.getElementById('defaultRemote').value;
  await saveSettings({ defaultRemote: remote });
}

// жӣҙж–°й»ҳи®ӨеҲҶж”Ҝ
async function updateDefaultBranch() {
  const branch = document.getElementById('defaultBranch').value;
  await saveSettings({ defaultBranch: branch });
}

// жӣҙж–°йҖҡзҹҘи®ҫзҪ®
async function updateNotification(type) {
  const settings = {
    notifications: {
      blocked: document.getElementById('blockedNotificationToggle').checked,
      taskDue: document.getElementById('taskDueNotificationToggle').checked,
      leadTime: parseInt(document.getElementById('notificationLeadTime').value)
    }
  };
  await saveSettings(settings);
}

// жӣҙж–°жҸҗйҶ’жҸҗеүҚж—¶й—ҙ
async function updateNotificationLeadTime() {
  const leadTime = parseInt(document.getElementById('notificationLeadTime').value);
  const settings = {
    notifications: {
      blocked: document.getElementById('blockedNotificationToggle').checked,
      taskDue: document.getElementById('taskDueNotificationToggle').checked,
      leadTime
    }
  };
  await saveSettings(settings);
}

// дҝқеӯҳи®ҫзҪ®
async function saveSettings(updates) {
  try {
    const response = await fetch(`${API_BASE}/settings`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(updates)
    });
    
    if (!response.ok) {
      console.error('Failed to save settings');
    }
  } catch (error) {
    console.error('Failed to save settings:', error);
  }
}

// жҳҫзӨәж·»еҠ и·Ҝеҫ„ Modal
// зӣ®еҪ•йҖүжӢ©еҷЁеӣһи°?function handleDirSelect(input) {
  if (input.files && input.files.length > 0) {
    // webkitdirectory иҝ”еӣһе®Ңж•ҙи·Ҝеҫ„пјҲChromium зі»жөҸи§ҲеҷЁпј?    const fullPath = input.files[0].path || input.files[0].webkitRelativePath.split('/')[0];
    document.getElementById('newPathInput').value = fullPath || '';
  }
}

function showAddPathModal() {
  document.getElementById('newPathId').value = '';
  document.getElementById('newPathInput').value = '';
  document.getElementById('newPathAlias').value = '';
  document.getElementById('newPathColor').value = '#3B82F6';
  document.getElementById('pathModalTitle').textContent = 'ж·»еҠ йЎ№зӣ®и·Ҝеҫ„';
  
  // йҮҚзҪ® confirmBtn зҠ¶жҖҒпјҲдҝ®еӨҚ editPath еҗ?confirmBtn д»ҚжҢҮеҗ?updatePath зҡ„й—®йўҳпјү
  const confirmBtn = document.querySelector('#addPathModal .btn-primary');
  if (confirmBtn) {
    confirmBtn.textContent = 'ж·»еҠ ';
    confirmBtn.onclick = addPath;
  }
  
  // е…ҲжҳҫзӨәеј№зӘ—пјҢеҶҚи§ҰеҸ‘зӣ®еҪ•йҖүжӢ©еҷ?  const modal = document.getElementById('addPathModal');
  modal.style.display = 'flex';
  
  // и§ҰеҸ‘йҡҗи—Ҹзҡ?webkitdirectory ж–Үд»¶йҖүжӢ©еҷ?  const dirPicker = document.getElementById('pathDirectoryPicker');
  if (dirPicker) {
    dirPicker.value = ''; // йҮҚзҪ®д»ҘдҫҝйҮҚеӨҚйҖүжӢ©еҗҢдёҖи·Ҝеҫ„
    dirPicker.click();
  }
}

// йҡҗи—Ҹж·»еҠ и·Ҝеҫ„ Modal
function hideAddPathModal() {
  document.getElementById('addPathModal').style.display = 'none';
  document.getElementById('newPathId').value = '';
  document.getElementById('newPathInput').value = '';
  document.getElementById('newPathAlias').value = '';
  document.getElementById('newPathColor').value = '#3B82F6';
}

// ж·»еҠ и·Ҝеҫ„
async function addPath() {
  const path = document.getElementById('newPathInput').value.trim();
  const alias = document.getElementById('newPathAlias').value.trim();
  const color = document.getElementById('newPathColor').value;
  
  if (!path) {
    alert('иҜ·иҫ“е…Ҙи·Ҝеҫ?);
    return;
  }
  
  try {
    const response = await fetch(`${API_BASE}/paths`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path, alias, color })
    });
    
    const result = await response.json();
    
    if (result.success) {
      hideAddPathModal();
      loadPaths();
    } else {
      alert('ж·»еҠ и·Ҝеҫ„еӨұиҙҘ: ' + result.error);
    }
  } catch (error) {
    console.error('Failed to add path:', error);
    alert('ж·»еҠ и·Ҝеҫ„еӨұиҙҘ');
  }
}

// зј–иҫ‘и·Ҝеҫ„
async function editPath(id) {
  const pathData = window.pathData || {};
  const path = pathData[id];
  
  if (!path) {
    alert('и·Ҝеҫ„дёҚеӯҳең?);
    return;
  }
  
  selectedColor = path.color || '#3B82F6';
  
  // еЎ«е……иЎЁеҚ•
  document.getElementById('newPathId').value = id;
  document.getElementById('newPathInput').value = path.path || '';
  document.getElementById('newPathAlias').value = path.alias || '';
  document.getElementById('newPathColor').value = selectedColor;
  
  // еҲҮжҚўжҢүй’®дёәжӣҙж–°жЁЎеј?  const modal = document.getElementById('addPathModal');
  const title = modal ? modal.querySelector('h3') : null;
  const confirmBtn = document.querySelector('#addPathModal .btn-primary');
  if (title) title.textContent = 'зј–иҫ‘и·Ҝеҫ„';
  if (confirmBtn) {
    confirmBtn.textContent = 'дҝқеӯҳ';
    confirmBtn.onclick = updatePath;
  }
  
  // жӣҙж–°йўңиүІйҖүжӢ©й«ҳдә®
  document.querySelectorAll('.color-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.color === selectedColor);
  });
  
  if (modal) modal.style.display = 'flex';
}

// жӣҙж–°и·Ҝеҫ„
async function updatePath() {
  const id = document.getElementById('newPathId').value;
  const path = document.getElementById('newPathInput').value.trim();
  const alias = document.getElementById('newPathAlias').value.trim();
  const color = document.getElementById('newPathColor').value;
  
  if (!id || !path) {
    alert('иҜ·еЎ«еҶҷе®Ңж•ҙдҝЎжҒ?);
    return;
  }
  
  try {
    const response = await fetch(`${API_BASE}/paths/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path, alias, color })
    });
    
    const result = await response.json();
    
    if (result.success) {
      hideAddPathModal();
      loadPaths();
    } else {
      alert('жӣҙж–°и·Ҝеҫ„еӨұиҙҘ: ' + result.error);
    }
  } catch (error) {
    console.error('Failed to update path:', error);
    alert('жӣҙж–°и·Ҝеҫ„еӨұиҙҘ');
  }
}

// еҲ йҷӨи·Ҝеҫ„
async function deletePath(id) {
  if (!confirm('зЎ®е®ҡиҰҒеҲ йҷӨжӯӨи·Ҝеҫ„еҗ—пјҹ')) return;
  
  try {
    const response = await fetch(`${API_BASE}/paths/${id}`, {
      method: 'DELETE'
    });
    
    const result = await response.json();
    
    if (result.success) {
      loadPaths();
    } else {
      alert('еҲ йҷӨи·Ҝеҫ„еӨұиҙҘ: ' + result.error);
    }
  } catch (error) {
    console.error('Failed to delete path:', error);
    alert('еҲ йҷӨи·Ҝеҫ„еӨұиҙҘ');
  }
}
</script>

<style>
.settings-container {
  max-width: 800px;
}

.settings-section {
  background: var(--color-card);
  border-radius: 12px;
  padding: var(--space-lg);
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  margin-bottom: var(--space-lg);
  padding-bottom: var(--space-sm);
  border-bottom: 1px solid var(--color-border);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) 0;
  border-bottom: 1px solid var(--color-border);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-weight: 500;
  margin-bottom: 2px;
}

.setting-description {
  font-size: var(--font-size-sm);
  color: var(--color-text-muted);
}

.setting-control {
  flex-shrink: 0;
  margin-left: var(--space-lg);
}

.setting-input {
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--color-border);
  border-radius: 6px;
  font-size: var(--font-size-sm);
  width: 200px;
}

.setting-input:focus {
  outline: none;
  border-color: var(--color-primary);
}

/* Toggle Switch */
.toggle {
  position: relative;
  display: inline-block;
  width: 44px;
  height: 24px;
