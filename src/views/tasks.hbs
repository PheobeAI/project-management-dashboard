</div>

<script>

// ه…¨ه±€çٹ¶و€?let tasksData = [];
let currentFilter = { status: 'all', type: 'all', assignee: 'all' };

// هˆ‌ه§‹هŒ?document.addEventListener('DOMContentLoaded', () => {
  // ه؛”ç”¨ن؟‌ه­کçڑ„ن¸»é¢?  const savedTheme = localStorage.getItem('theme');
  if (savedTheme) document.documentElement.setAttribute('data-theme', savedTheme);
  
  loadTasks();
});

// هٹ è½½ن»»هٹ،و•°وچ®
async function loadTasks() {
  showLoading(true);
  
  try {
    // هٹ è½½ç»ںè®،
    const statsResponse = await fetch(`${API_BASE}/tasks/stats`);
    const statsResult = await statsResponse.json();
    
    if (statsResult.success) {
      renderTaskStats(statsResult.data);
    }
    
    // هٹ è½½ن»»هٹ،هˆ—è،¨
    const response = await fetch(`${API_BASE}/tasks`);
    const result = await response.json();
    
    if (result.success) {
      tasksData = result.data;
      renderTasks(tasksData);
    }
  } catch (error) {
    console.error('Failed to load tasks:', error);
    showError('هٹ è½½ن»»هٹ،و•°وچ®ه¤±è´¥');
  } finally {
    showLoading(false);
  }
}

// و¸²وں“ن»»هٹ،ç»ںè®،
function renderTaskStats(stats) {
  document.getElementById('statTotal').textContent = stats.total || 0;
  document.getElementById('statWaiting').textContent = stats.waiting || 0;
  document.getElementById('statInProgress').textContent = stats.inProgress || 0;
  document.getElementById('statDone').textContent = stats.done || 0;
}

// و¸²وں“ن»»هٹ،هˆ—è،¨
function renderTasks(tasks) {
  const container = document.getElementById('tasksContainer');
  const emptyState = document.getElementById('emptyState');
  
  if (!tasks || tasks.length === 0) {
    container.style.display = 'none';
    emptyState.style.display = 'flex';
    return;
  }
  
  container.style.display = 'block';
  emptyState.style.display = 'none';
  
  // وŒ‰çٹ¶و€پهˆ†ç»?  const grouped = {
    waiting: tasks.filter(t => t.status === 'waiting'),
    in_progress: tasks.filter(t => t.status === 'in_progress'),
    done: tasks.filter(t => t.status === 'done'),
    cancelled: tasks.filter(t => t.status === 'cancelled')
  };
  
  const statusLabels = {
    waiting: { icon: '/assets/icons/status-waiting.svg', label: 'ç­‰ه¾…ن¸?, color: '#F59E0B' },
    in_progress: { icon: '/assets/icons/status-in-progress.svg', label: 'è؟›è،Œن¸?, color: '#3B82F6' },
    done: { icon: '/assets/icons/status-done.svg', label: 'ه·²ه®Œوˆ?, color: '#10B981' },
    cancelled: { icon: '/assets/icons/status-cancelled.svg', label: 'ه·²هڈ–و¶?, color: '#6B7280' }
  };
  
  let html = '';
  
  for (const [status, items] of Object.entries(grouped)) {
    if (items.length === 0) continue;
    
    const info = statusLabels[status];
    
    html += `
      <div class="task-group">
        <div class="task-group-header" style="border-left-color: ${info.color}">
          <span class="task-group-icon"><img src="${info.icon}" alt="${info.label}"></span>
          <span class="task-group-label">${info.label}</span>
          <span class="task-group-count">(${items.length})</span>
        </div>
        <div class="task-group-list">
          ${items.map(task => renderTaskItem(task)).join('')}
        </div>
      </div>
    `;
  }
  
  container.innerHTML = html || '<p class="no-tasks">و²،وœ‰ç¬¦هگˆç­›é€‰و‌،ن»¶çڑ„ن»»هٹ،</p>';
}

function renderTaskItem(task) {
  const typeIcons = {
    dev: '/assets/icons/agent-engineer.svg',
    art: '/assets/icons/agent-art.svg',
    test: '/assets/icons/agent-qa.svg',
    other: '/assets/icons/folder.svg'
  };
  const taskType = (task.type || 'other').toLowerCase();
  const typeIcon = typeIcons[taskType] || typeIcons.other;
  const dueDate = task.due ? new Date(task.due).toLocaleDateString('zh-CN') : '-';
  const isOverdue = task.due && new Date(task.due) < new Date() && task.status !== 'done';
  
  return `
    <div class="task-item ${isOverdue ? 'overdue' : ''}">
      <div class="task-type"><img src="${typeIcon}" alt="${task.type}"></div>
      <div class="task-content">
        <div class="task-title">${task.title || task.id}</div>
        <div class="task-meta">
          <span class="task-project">${task.projectName || 'وœھçں¥é،¹ç›®'}</span>
          <span class="task-assignee"><img src="/assets/icons/agent-pm.svg" alt="assignee" style="width:16px;height:16px;vertical-align:middle;"> ${task.assignee || 'وœھهˆ†é…?}</span>
          <span class="task-due ${isOverdue ? 'overdue' : ''}">ًں“… ${dueDate}</span>
        </div>
      </div>
      <div class="task-actions">
        <button class="btn btn-sm" onclick="viewTask('${task.id}')">è¯¦وƒ…</button>
      </div>
    </div>
  `;
}

// ç­›é€‰ن»»هٹ?function filterTasks() {
  currentFilter.status = document.getElementById('statusFilter').value;
  currentFilter.type = document.getElementById('typeFilter').value;
  currentFilter.assignee = document.getElementById('assigneeFilter').value;
  
  let filtered = [...tasksData];
  
  if (currentFilter.status !== 'all') {
    filtered = filtered.filter(t => t.status === currentFilter.status);
  }
  
  if (currentFilter.type !== 'all') {
    filtered = filtered.filter(t => t.type && t.type.toLowerCase() === currentFilter.type.toLowerCase());
  }
  
  if (currentFilter.assignee !== 'all') {
    filtered = filtered.filter(t => t.assignee === currentFilter.assignee);
  }
  
  renderTasks(filtered);
}

// وں¥çœ‹ن»»هٹ،è¯¦وƒ…
function viewTask(taskId) {
  const task = tasksData.find(t => t.id === taskId);
  if (task) {
    alert(`ن»»هٹ،: ${task.title || taskId}\nçٹ¶و€? ${task.status}\nç±»ه‍‹: ${task.type}\nè´ںè´£ن؛? ${task.assignee || 'وœھهˆ†é…?}\né،¹ç›®: ${task.projectName || 'وœھçں¥'}`);
  }
}

function showLoading(show) {
  document.getElementById('loadingState').style.display = show ? 'flex' : 'none';
}

function showError(message) {
  alert(message);
}

function refreshTasks() {
  loadTasks();
}
</script>

