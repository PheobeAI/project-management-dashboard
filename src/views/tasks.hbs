</div>

<!-- ن»»هٹ،هˆ—è،¨ -->
<div class="tasks-container" id="tasksContainer">
  <!-- وŒ‰çٹ¶و€پهˆ†ç»„çڑ„ن»»هٹ، -->
</div>

<!-- ç©؛çٹ¶و€?-->
<div class="empty-state" id="emptyState" style="display: none;">
  <div class="empty-state-icon">ًں“‹</div>
  <div class="empty-state-title">وڑ‚و— ن»»هٹ،و•°وچ®</div>
