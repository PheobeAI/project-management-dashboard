{{! Versions Page }}

<div class="page-header">
  <h1 class="page-title">🏷️ 版本历史</h1>
  <div class="page-actions">
    <button class="btn btn-secondary" onclick="refreshVersions()">
      <span class="btn-icon">🔄</span> 刷新
    </button>
  </div>
</div>

<!-- 加载状态 -->
<div class="loading-state" id="loadingState">
  <div class="spinner"></div>
  <p>加载版本数据...</p>
</div>

<!-- 版本列表 -->
<div class="versions-container" id="versionsContainer">
  <!-- 版本项将在这里渲染 -->
</div>

<!-- 空状态 -->
<div class="empty-state" id="emptyState" style="display: none;">
  <div class="empty-state-icon">🏷️</div>
  <div class="empty-state-title">暂无版本数据</div>
  <div class="empty-state-description">当前没有项目包含版本记录。<br>版本数据存储在 <code>.project/versions/</code> 目录。</div>
</div>

<script>

// 全局状态
let versionsData = [];

document.addEventListener('DOMContentLoaded', () => {
  loadVersions();
});

async function loadVersions() {
  showLoading(true);
  
  try {
    const response = await fetch(`${API_BASE}/versions`);
    const result = await response.json();
    
    if (result.success) {
      versionsData = result.data;
      renderVersions(versionsData);
    } else {
      showError('加载版本数据失败');
    }
  } catch (error) {
    console.error('Failed to load versions:', error);
    showError('加载版本数据失败');
  } finally {
    showLoading(false);
  }
}

function renderVersions(versions) {
  const container = document.getElementById('versionsContainer');
  const emptyState = document.getElementById('emptyState');
  
  if (!versions || versions.length === 0) {
    container.style.display = 'none';
    emptyState.style.display = 'flex';
    return;
  }
  
  container.style.display = 'block';
  emptyState.style.display = 'none';
  
  // 按项目分组
  const grouped = {};
  versions.forEach(v => {
    const projectName = v.projectName || '未知项目';
    if (!grouped[projectName]) {
      grouped[projectName] = [];
    }
    grouped[projectName].push(v);
  });
  
  let html = '';
  
  for (const [projectName, items] of Object.entries(grouped)) {
    html += `
      <div class="version-group">
        <div class="version-group-header">
          <span class="project-icon">📁</span>
          <span class="project-name">${projectName}</span>
          <span class="version-count">${items.length} 个版本</span>
        </div>
        <div class="version-list">
          ${items.map(v => renderVersionItem(v)).join('')}
        </div>
      </div>
    `;
  }
  
  container.innerHTML = html || '<p class="no-versions">没有版本数据</p>';
}

function renderVersionItem(version) {
  const date = version.date ? new Date(version.date).toLocaleDateString('zh-CN') : '-';
  const changes = version.changes || [];
  
  return `
    <div class="version-item">
      <div class="version-tag">
        <span class="tag-icon">🏷️</span>
        <span class="tag-name">${version.tag || version.version || 'v0.0.0'}</span>
      </div>
      <div class="version-content">
        <div class="version-date">📅 ${date}</div>
        ${changes.length > 0 ? `
          <div class="version-changes">
            ${changes.map(c => `<span class="change-tag ${c.type}">${getChangeIcon(c.type)} ${c.desc}</span>`).join('')}
          </div>
        ` : ''}
      </div>
      <div class="version-actions">
        <button class="btn btn-sm" onclick="viewVersionDetail('${version.tag || version.version}')">详情</button>
      </div>
    </div>
  `;
}

function getChangeIcon(type) {
  const icons = {
    feature: '✨',
    bugfix: '🐛',
    hotfix: '🔥',
    docs: '📝',
    refactor: '🔧',
    test: '🧪'
  };
  return icons[type] || '📌';
}

function viewVersionDetail(tag) {
  const version = versionsData.find(v => v.tag === tag || v.version === tag);
  if (version) {
    alert(`版本: ${version.tag || version.version}\n日期: ${version.date || '-'}\n项目: ${version.projectName || '未知'}\n变更: ${JSON.stringify(version.changes || [], null, 2)}`);
  }
}

function showLoading(show) {
  document.getElementById('loadingState').style.display = show ? 'flex' : 'none';
}

function showError(message) {
  alert(message);
}

function refreshVersions() {
  loadVersions();
}
</script>

